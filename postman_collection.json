        {
          "name": "Login User 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set('user1_token', response.data.token);",
                  "    console.log('User 1 Token Saved:', response.data.token);",
                  "}"
                ]
              }
            }
