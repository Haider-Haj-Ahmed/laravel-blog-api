    {
      "name": "Posts",
      "item": [
        {
          "name": "Create Post (User 1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set('post_id', response.data.id);",
                  "    console.log('Post ID Saved:', response.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user1_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{post_title}}\",\n  \"body\": \"{{post_body}}\",\n  \"is_published\": true\n}"
            },
            "url": {
              "raw": "{{api_url}}/posts",
              "host": [
                "{{api_url}}"
              ],
              "path": [
                "posts"
              ]
            }
          }
        },
