      "item": [
        {
          "name": "Register User 1",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{user1_name}}\",\n  \"email\": \"{{user1_email}}\",\n  \"password\": \"{{user1_password}}\",\n  \"password_confirmation\": \"{{user1_password}}\",\n  \"username\": \"{{user1_username}}\",\n  \"phone\": \"{{user1_phone}}\"\n}"
            },
            "url": {
              "raw": "{{api_url}}/register",
              "host": [
                "{{api_url}}"
              ],
              "path": [
                "register"
              ]
            }
